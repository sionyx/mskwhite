# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# Токен платежного провайдера от @BotFather
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# Опционально: отдельные токены для тестового режима из README
TEST_BOT_TOKEN=your_test_bot_token_here
TEST_PAYMENT_PROVIDER_TOKEN=your_test_payment_provider_token_here

# Telegram user ID администратора, которому доступны служебные команды
ADMIN_USER_ID=123456789

# Параметры подключения к Outline Server API
OUTLINE_API_URL=https://your-outline-server.example.com/your-management-path
OUTLINE_CERT_SHA256=your_outline_cert_sha256_here

# Лимит использованного трафика в МБ для возврата через /paysupport
PAY_SUPPORT_LIMIT_MB=100
